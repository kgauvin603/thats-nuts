# Core app settings
APP_NAME="Thats Nuts API"
ENVIRONMENT=dev
APP_HOST=0.0.0.0
APP_PORT=8002
APP_RELOAD=false
APP_LOG_LEVEL=info

# Dependency installation control for scripts/run_backend.sh
INSTALL_DEPS=true

# Default local database for stable single-host deployment
DATABASE_URL=sqlite:///./thatsnuts.db
DATABASE_ECHO=false
DATABASE_AUTO_CREATE=true
DATABASE_SEED_DATA=true

# Example PostgreSQL URL for later use:
# DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/thatsnuts

# Product lookup provider
PRODUCT_LOOKUP_PROVIDER=food_then_beauty
PRODUCT_LOOKUP_BEAUTY_BASE_URL=https://world.openbeautyfacts.org
PRODUCT_LOOKUP_FOOD_BASE_URL=https://world.openfoodfacts.org
# Legacy alias still supported for the food provider base URL:
# PRODUCT_LOOKUP_BASE_URL=https://world.openfoodfacts.org
PRODUCT_LOOKUP_API_KEY=
PRODUCT_LOOKUP_USER_AGENT="ThatsNuts/1.0 - contact: support@activeadvantage.co"
PRODUCT_LOOKUP_TIMEOUT_SECONDS=5.0
